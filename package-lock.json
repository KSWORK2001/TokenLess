{
  "name": "tokenless-workspace",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "tokenless-workspace",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@kswork2001/tokenless": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@kswork2001/tokenless-darwin-arm64": {
      "resolved": "packages/distill-darwin-arm64",
      "link": true
    },
    "node_modules/@kswork2001/tokenless-darwin-x64": {
      "resolved": "packages/distill-darwin-x64",
      "link": true
    },
    "node_modules/@kswork2001/tokenless-linux-arm64": {
      "resolved": "packages/distill-linux-arm64",
      "link": true
    },
    "node_modules/@kswork2001/tokenless-linux-x64": {
      "resolved": "packages/distill-linux-x64",
      "link": true
    },
    "node_modules/@kswork2001/tokenless-win32-x64": {
      "resolved": "packages/distill-win32-x64",
      "link": true
    },
    "packages/cli": {
      "name": "@kswork2001/tokenless",
      "version": "1.4.1",
      "license": "MIT",
      "bin": {
        "TokenLess": "bin/distill.js"
      },
      "engines": {
        "node": ">=18"
      },
      "optionalDependencies": {
        "@kswork2001/tokenless-darwin-arm64": "1.4.1",
        "@kswork2001/tokenless-darwin-x64": "1.4.1",
        "@kswork2001/tokenless-linux-arm64": "1.4.1",
        "@kswork2001/tokenless-linux-x64": "1.4.1",
        "@kswork2001/tokenless-win32-x64": "1.4.1"
      }
    },
    "packages/distill-darwin-arm64": {
      "name": "@kswork2001/tokenless-darwin-arm64",
      "version": "1.4.1",
      "license": "MIT"
    },
    "packages/distill-darwin-x64": {
      "name": "@kswork2001/tokenless-darwin-x64",
      "version": "1.4.1",
      "license": "MIT"
    },
    "packages/distill-linux-arm64": {
      "name": "@kswork2001/tokenless-linux-arm64",
      "version": "1.4.1",
      "license": "MIT"
    },
    "packages/distill-linux-x64": {
      "name": "@kswork2001/tokenless-linux-x64",
      "version": "1.4.1",
      "license": "MIT"
    },
    "packages/distill-win32-x64": {
      "name": "@kswork2001/tokenless-win32-x64",
      "version": "1.4.1",
      "license": "MIT"
    }
  }
}
